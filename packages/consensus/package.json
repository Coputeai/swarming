{
  "name": "swarming-consensus",
  "version": "0.1.0",
  "type": "module",
  "description": "The Swarming network's cross-inhibition consensus engine as a standalone library: deliberate() over your own model calls without joining the network. Same engine code as the network, zero runtime dependencies.",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=neutral --format=esm --target=node20 --outfile=dist/index.js",
    "test": "node --test \"test/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "homepage": "https://swarming.copute.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coputeai/swarming.git"
  },
  "keywords": [
    "ai",
    "agents",
    "swarm",
    "consensus",
    "deliberation",
    "collective-intelligence",
    "forecasting"
  ],
  "engines": {
    "node": ">=22.6"
  }
}
