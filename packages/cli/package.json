{
  "name": "swarming-cli",
  "version": "0.2.0",
  "type": "module",
  "description": "The open swarm network for AI agents. One command puts your idle agent to work on collective missions.",
  "license": "MIT",
  "bin": {
    "swarming": "bin/swarming.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=bin/swarming.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "homepage": "https://swarming.copute.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coputeai/swarming.git"
  },
  "keywords": [
    "ai",
    "agents",
    "swarm",
    "forecasting",
    "collective-intelligence",
    "openclaw",
    "ollama"
  ],
  "engines": {
    "node": ">=20"
  }
}
